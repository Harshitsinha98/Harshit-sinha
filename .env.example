# Copy this file to .env.local for local development.
# In production (Vercel), set these as Environment Variables in the
# project's Settings -> Environment Variables tab instead.

# Redis (testimonials storage) — added automatically when you connect an
# Upstash Redis database from the Vercel Marketplace (Storage tab -> Browse
# Storage -> Upstash -> Redis). NOTE: pick "Upstash", not the plain "Redis"
# (Redis Cloud) option at the top of that list — Redis Cloud uses a
# different connection format this app doesn't support.
# Depending on how the Upstash store was connected, Vercel names these
# either KV_REST_API_URL/KV_REST_API_TOKEN or UPSTASH_REDIS_REST_URL/
# UPSTASH_REDIS_REST_TOKEN — this app accepts either pair, so just copy
# whichever one Vercel actually gave you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# The password you type at /admin/login to manage testimonials.
# Pick something only you know — this is the only thing protecting the
# admin panel.
ADMIN_PASSWORD=

# Optional: require your manual approval before a new testimonial appears
# on the site. Defaults to false (auto-publish immediately on submit).
# Set to "true" to switch to an approve-before-publish workflow instead.
REQUIRE_TESTIMONIAL_APPROVAL=false
